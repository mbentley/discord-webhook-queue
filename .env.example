# discord-webhook-queue configuration
# Copy this file to .env and edit as needed.
#
# NOTE: This file is only read by the Docker runtime (via --env-file or
# docker-compose env_file). If you run the binary directly, you must set
# these variables in your environment before launching the process.

# Address and port to listen on (default: :8080)
# LISTEN_ADDR=:8080

# Path to the SQLite database file (default: /data/queue.db)
# Must be inside a Docker volume for persistence across restarts.
# DB_PATH=/data/queue.db

# Seconds between delivery retry attempts when Discord is unreachable.
# Minimum: 5, Maximum: 300, Default: 30
# RETRY_INTERVAL_SECONDS=30

# --- Authentication (optional) ---
# If AUTH_TOKEN is set, the /status and /metrics endpoints require the token
# in the configured request header. The ingest endpoint (POST /webhooks/...)
# is NEVER auth-gated — senders like discord.sh and Grafana cannot inject
# custom headers, so requiring a token there would break them.
# Leave AUTH_TOKEN unset to allow open access (trusted-network assumption).
# AUTH_TOKEN=your-secret-token-here
# AUTH_HEADER=X-Auth-Token

# --- SMTP Alerting (optional) ---
# Leave SMTP_HOST unset to disable email alerts entirely.
# Alerts fire after FAILURE_ALERT_AFTER_MINUTES of sustained Discord failure,
# then every 24 hours if the failure continues.

# Minutes of sustained delivery failure before the first alert email is sent.
# Minimum: 1, Maximum: 1440 (24 hours), Default: 15
# FAILURE_ALERT_AFTER_MINUTES=15

# SMTP_HOST=mail.example.com
# SMTP_PORT=25
# SMTP_FROM=discord-webhook-queue@example.com
# SMTP_TO=alerts@example.com

# Enable STARTTLS (true/false, default: false)
# SMTP_STARTTLS=false

# SMTP credentials — leave unset for unauthenticated relay
# SMTP_USERNAME=
# SMTP_PASSWORD=

# Label shown in alert email subjects to identify this instance.
# Defaults to the system hostname (obfuscated inside Docker — set this explicitly).
# ALERT_HOST_LABEL=my-homelab-server
